<script>
  let typeTimer: ReturnType<typeof setInterval> | null = null;

  function initShowcase() {
    const pills = document.querySelectorAll<HTMLButtonElement>('.prompt-pill');
    pills.forEach((pill) => {
      pill.addEventListener('click', () => handlePillClick(pill));
    });
  }

  function handlePillClick(pill: HTMLButtonElement) {
    const text = pill.dataset.prompt;
    if (!text) return;

    const promptEl = document.getElementById('demo-prompt-text') as HTMLSpanElement | null;
    const sendBtn = document.querySelector<HTMLDivElement>('.demo-send-btn');
    const panels = document.querySelectorAll<HTMLDivElement>('.demo-panel');
    if (!promptEl || !sendBtn) return;

    // Clear any running type animation
    if (typeTimer) {
      clearInterval(typeTimer);
      typeTimer = null;
    }

    // Stop CSS animations on default panel
    const defaultPanel = document.querySelector<HTMLDivElement>('[data-demo="default"]');
    if (defaultPanel) {
      defaultPanel.style.animation = 'none';
      defaultPanel.querySelectorAll<HTMLDivElement>('.demo-el').forEach((e) => { e.style.animation = 'none'; });
      defaultPanel.querySelectorAll<HTMLDivElement>('.demo-bar').forEach((b) => { b.style.animation = 'none'; });
    }

    // Hide all panels
    panels.forEach((p) => {
      p.style.opacity = '0';
      p.style.transition = 'none';
      p.classList.add('hidden');
    });

    // Find matching panel
    const target = document.querySelector<HTMLDivElement>(`[data-demo="${text}"]`) ?? defaultPanel;
    if (!target) return;

    // Reset prompt bar
    promptEl.style.animation = 'none';
    promptEl.classList.remove('demo-prompt');
    promptEl.textContent = '';
    sendBtn.style.animation = 'none';
    sendBtn.style.opacity = '0.3';

    // Scroll into view
    const section = promptEl.closest('section');
    section?.scrollIntoView({ behavior: 'smooth', block: 'center' });

    // Type out the prompt letter by letter
    let i = 0;
    typeTimer = setInterval(() => {
      if (i < text.length) {
        promptEl.textContent += text[i];
        i++;
      } else {
        clearInterval(typeTimer!);
        typeTimer = null;
        sendBtn.style.opacity = '1';

        setTimeout(() => {
          target.classList.remove('hidden');
          target.offsetHeight; // force reflow
          target.style.transition = 'opacity 0.5s ease-out';
          target.style.opacity = '1';
        }, 400);
      }
    }, 45);

    // Highlight active pill
    document.querySelectorAll('.prompt-pill').forEach((p) => p.classList.remove('prompt-pill-active'));
    pill.classList.add('prompt-pill-active');
  }

  initShowcase();
</script>

<style>
  /* === PROMPT PILLS === */
  .prompt-pill {
    font-family: "Kalam", cursive;
    font-size: 0.95rem;
    color: rgba(250, 250, 249, 0.5);
    border: 2px solid rgba(250, 250, 249, 0.12);
    padding: 0.4rem 1rem;
    border-radius: 9999px;
    transition: all 0.3s;
    white-space: nowrap;
    cursor: pointer;
  }
  .prompt-pill:hover {
    color: #2dd4bf;
    border-color: rgba(45, 212, 191, 0.4);
    transform: rotate(0deg) scale(1.05) !important;
  }
  .prompt-pill-active {
    color: #2dd4bf;
    border-color: #2dd4bf;
    background: rgba(45, 212, 191, 0.1);
    transform: rotate(0deg) scale(1.05) !important;
  }

  /* === SHOWCASE ANIMATIONS === */
  @keyframes cursor-blink {
    0%, 49% { opacity: 1; }
    50%, 100% { opacity: 0; }
  }
  .demo-cursor { animation: cursor-blink 0.6s step-end infinite; }

  @keyframes type-prompt {
    0% { content: ""; }
    3% { content: "b"; } 5% { content: "bu"; } 7% { content: "bui"; }
    9% { content: "buil"; } 11% { content: "build"; } 13% { content: "build "; }
    15% { content: "build m"; } 17% { content: "build me"; } 19% { content: "build me "; }
    21% { content: "build me a"; } 23% { content: "build me a "; }
    25% { content: "build me a s"; } 26% { content: "build me a sa"; }
    27% { content: "build me a sal"; } 28% { content: "build me a sale"; }
    29% { content: "build me a sales"; } 30% { content: "build me a sales "; }
    31% { content: "build me a sales d"; } 32% { content: "build me a sales da"; }
    33% { content: "build me a sales das"; } 34% { content: "build me a sales dash"; }
    35% { content: "build me a sales dashb"; } 36% { content: "build me a sales dashbo"; }
    37% { content: "build me a sales dashboa"; } 38% { content: "build me a sales dashboar"; }
    39% { content: "build me a sales dashboard"; }
    39%, 85% { content: "build me a sales dashboard"; }
    95%, 100% { content: ""; }
  }
  .demo-prompt::before {
    content: "";
    animation: type-prompt 10s linear infinite;
  }

  @keyframes send-glow {
    0%, 30% { opacity: 0.3; }
    35%, 80% { opacity: 1; }
    90%, 100% { opacity: 0.3; }
  }
  .demo-send-btn { animation: send-glow 10s linear infinite; }

  @keyframes ui-appear {
    0%, 35% { opacity: 0; }
    40%, 85% { opacity: 1; }
    92%, 100% { opacity: 0; }
  }
  .demo-ui { animation: ui-appear 10s ease-out infinite; }

  @keyframes el-slide-1 {
    0%, 36% { opacity: 0; transform: translateY(12px); }
    42%, 85% { opacity: 1; transform: translateY(0); }
    92%, 100% { opacity: 0; transform: translateY(12px); }
  }
