---
interface Prompt {
  text: string;
  rotate: string;
}

const prompts: Prompt[] = [
  { text: "build me a landing page", rotate: "-rotate-1" },
  { text: "switch to brutalist style", rotate: "rotate-[0.5deg]" },
  { text: "create an ad visual", rotate: "-rotate-[0.5deg]" },
  { text: "add a dark mode toggle", rotate: "rotate-1" },
  { text: "show my Notion data as charts", rotate: "-rotate-[1.5deg]" },
  { text: "make it mobile-friendly", rotate: "rotate-[0.8deg]" },
